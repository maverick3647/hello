#include <stdio.h>

void fifo(int pages[], int n, int frames) {
    int memory[10], i, j, k = 0, faults = 0, found;

    for(i = 0; i < frames; i++)
        memory[i] = -1;

    for(i = 0; i < n; i++) {
        found = 0;

        for(j = 0; j < frames; j++) {
            if(memory[j] == pages[i]) {
                found = 1;
                break;
            }
        }

        if(!found) {
            memory[k] = pages[i];
            k = (k + 1) % frames;
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for(j = 0; j < frames; j++) {
            if(memory[j] != -1)
                printf("%d ", memory[j]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("Total Page Faults (FIFO): %d\n", faults);
}

void lru(int pages[], int n, int frames) {
    int memory[10], time[10];
    int i, j, pos, faults = 0, counter = 0, found;

    for(i = 0; i < frames; i++) {
        memory[i] = -1;
        time[i] = 0;
    }

    for(i = 0; i < n; i++) {
        found = 0;

        for(j = 0; j < frames; j++) {
            if(memory[j] == pages[i]) {
                counter++;
                time[j] = counter;
                found = 1;
                break;
            }
        }

        if(!found) {
            pos = 0;
            for(j = 1; j < frames; j++) {
                if(time[j] < time[pos])
                    pos = j;
            }

            memory[pos] = pages[i];
            counter++;
            time[pos] = counter;
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for(j = 0; j < frames; j++) {
            if(memory[j] != -1)
                printf("%d ", memory[j]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("Total Page Faults (LRU): %d\n", faults);
}

int main() {
    int pages[20], n, frames;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string:\n");
    for(int i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("\n--- FIFO ---\n");
    fifo(pages, n, frames);

    printf("\n--- LRU ---\n");
    lru(pages, n, frames);

    return 0;
}
