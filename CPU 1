#include <stdio.h>

void fcfs(int bt[], int n) {
    int wt[10], tat[10];

    wt[0] = 0;

    for(int i = 1; i < n; i++) {
        wt[i] = wt[i - 1] + bt[i - 1];
    }

    for(int i = 0; i < n; i++) {
        tat[i] = wt[i] + bt[i];
        printf("P%d %d %d %d\n", i + 1, bt[i], wt[i], tat[i]);
    }
}

int main() {
    int n, bt[10];

    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        scanf("%d", &bt[i]);
    }

    fcfs(bt, n);

    return 0;
}
